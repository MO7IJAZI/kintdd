generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

model Category {
  id             String     @id @default(cuid())
  name           String
  slug           String     @unique
  description    String?    @db.Text
  image          String?
  parentId       String?
  order          Int        @default(0)
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  description_ar String?    @db.Text
  name_ar        String
  icon           String?
  parent         Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children       Category[] @relation("CategoryToCategory")
  products       Product[]

  @@index([slug])
  @@index([parentId])
  @@map("categories")
}

model Product {
  id             String           @id @default(cuid())
  name           String
  slug           String           @unique
  description    String?          @db.Text
  shortDesc      String?          @db.Text
  features       String?          @db.Text
  benefits       String?          @db.Text
  usage          String?          @db.Text
  composition    String?          @db.Text
  image          String?
  categoryId     String
  isOrganic      Boolean          @default(false)
  isFeatured     Boolean          @default(false)
  isActive       Boolean          @default(true)
  order          Int              @default(0)
  metaTitle      String?
  metaDesc       String?          @db.Text
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  compTable      String?          @db.LongText
  sku            String?          @unique
  usageTable     String?          @db.LongText
  benefits_ar    String?          @db.Text
  compTable_ar   String?          @db.LongText
  composition_ar String?          @db.Text
  description_ar String?          @db.Text
  features_ar    String?          @db.Text
  metaDesc_ar    String?          @db.Text
  metaTitle_ar   String?
  name_ar        String?
  shortDesc_ar   String?          @db.Text
  tabs           String?          @db.LongText
  tabs_ar        String?          @db.LongText
  usageTable_ar  String?          @db.LongText
  usage_ar       String?          @db.Text
  colorTheme     String           @default("blue")
  downloads      Download[]
  images         ProductImage[]
  sections       ProductSection[]
  category       Category         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  animal_types   AnimalType[]     @relation("animaltypetoproduct")
  crops          Crop[]           @relation("croprecommendedproducts")

  @@index([slug])
  @@index([categoryId])
  @@index([isFeatured])
  @@index([order])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  order     Int      @default(0)
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model Download {
  id         String   @id @default(cuid())
  title      String
  fileUrl    String
  type       String
  productId  String?
  createdAt  DateTime @default(now())
  fileUrl_ar String?
  title_ar   String?
  product    Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("downloads")
}

model ProductSection {
  id         String   @id @default(cuid())
  title      String
  title_ar   String?
  content    String   @db.LongText
  content_ar String?  @db.LongText
  order      Int      @default(0)
  colorTheme String   @default("blue")
  productId  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([order])
  @@map("product_sections")
}

model Catalog {
  id             String   @id @default(cuid())
  title          String
  title_ar       String?
  description    String?  @db.Text
  description_ar String?  @db.Text
  fileUrl        String
  category       String
  order          Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  fileUrl_ar     String?

  @@index([category])
  @@index([isActive])
  @@index([order])
  @@map("catalogs")
}

model Headquarter {
  id         String   @id @default(cuid())
  title      String   @default("Company Headquarter")
  title_ar   String?  @default("مقر الشركة")
  content    String?  @db.Text
  content_ar String?  @db.Text
  address    String?
  address_ar String?
  latitude   Float?
  longitude  Float?
  updatedAt  DateTime @updatedAt

  @@map("headquarters")
}

model Crop {
  id               String      @id @default(cuid())
  name             String
  slug             String      @unique
  image            String?
  pdfUrl           String?
  description      String?     @db.Text
  isActive         Boolean     @default(true)
  metaTitle        String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  description_ar   String?     @db.Text
  harvestSeason_ar String?
  metaTitle_ar     String?
  name_ar          String?
  category         String?
  category_ar      String?
  pdfUrl_ar        String?
  documentIcon     String?
  documentTitle    String?
  documentTitle_ar String?
  stages           CropStage[]
  products         Product[]   @relation("croprecommendedproducts")

  @@index([slug])
  @@index([category])
  @@map("crops")
}

model CropStage {
  id             String   @id @default(cuid())
  name           String
  order          Int      @default(0)
  cropId         String
  recommendation String?  @db.LongText
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  name_ar        String?
  description    String?  @db.Text
  description_ar String?  @db.Text
  crop           Crop     @relation(fields: [cropId], references: [id], onDelete: Cascade)

  @@index([cropId])
  @@map("crop_stages")
}

model BlogPost {
  id           String    @id @default(cuid())
  title        String
  slug         String    @unique
  excerpt      String?   @db.Text
  content      String    @db.LongText
  image        String?
  author       String
  tags         String?   @db.Text
  isPublished  Boolean   @default(false)
  publishedAt  DateTime?
  metaTitle    String?
  metaDesc     String?   @db.Text
  views        Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  content_ar   String?   @db.LongText
  excerpt_ar   String?   @db.Text
  metaDesc_ar  String?   @db.Text
  metaTitle_ar String?
  title_ar     String?
  author_ar    String?
  tags_ar      String?   @db.Text

  @@index([slug])
  @@index([isPublished])
  @@index([publishedAt])
  @@map("blog_posts")
}

model Page {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  content    String   @db.LongText
  template   String   @default("default")
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  content_ar String?  @db.LongText
  title_ar   String?

  @@index([slug])
  @@map("pages")
}

model ContactSubmission {
  id         String   @id @default(cuid())
  name       String
  email      String
  phone      String?
  subject    String?
  message    String   @db.Text
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  department String?

  @@index([isRead])
  @@index([createdAt])
  @@map("contact_submissions")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model ExpertArticle {
  id           String    @id @default(cuid())
  title        String
  slug         String    @unique
  excerpt      String?   @db.Text
  content      String    @db.LongText
  image        String?
  category     String
  order        Int       @default(0)
  isPublished  Boolean   @default(true)
  publishedAt  DateTime?
  metaTitle    String?
  metaDesc     String?   @db.Text
  views        Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  content_ar   String?   @db.LongText
  excerpt_ar   String?   @db.Text
  metaDesc_ar  String?   @db.Text
  metaTitle_ar String?
  title_ar     String?

  @@index([slug])
  @@index([category])
  @@index([isPublished])
  @@index([order])
  @@map("expert_articles")
}

model JobOffer {
  id                  String           @id @default(cuid())
  title               String
  location            String?
  workType            String?
  contractType        String?
  employmentType      String?
  companyIntro        String?          @db.Text
  responsibilities    String?          @db.Text
  benefits            String?          @db.Text
  qualifications      String?          @db.Text
  isActive            Boolean          @default(true)
  publishedAt         DateTime         @default(now())
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  benefits_ar         String?          @db.Text
  companyIntro_ar     String?          @db.Text
  contractType_ar     String?
  employmentType_ar   String?
  location_ar         String?
  qualifications_ar   String?          @db.Text
  responsibilities_ar String?          @db.Text
  title_ar            String?
  workType_ar         String?
  expiresAt           DateTime?
  applications        JobApplication[]

  @@index([isActive])
  @@index([publishedAt])
  @@map("job_offers")
}

model JobApplication {
  id          String   @id @default(cuid())
  jobOfferId  String
  firstName   String
  lastName    String
  email       String
  phone       String?
  address     String?  @db.Text
  linkedIn    String?
  cvUrl       String?  @db.Text
  coverLetter String?  @db.Text
  status      String   @default("pending")
  notes       String?  @db.Text
  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
  jobOffer    JobOffer @relation(fields: [jobOfferId], references: [id], onDelete: Cascade)

  @@index([jobOfferId])
  @@index([status])
  @@index([submittedAt])
  @@map("job_applications")
}

model Document {
  id             String   @id @default(cuid())
  title          String
  title_ar       String?
  slug           String   @unique
  description    String?  @db.Text
  description_ar String?  @db.Text
  filePath       String
  category       String
  isActive       Boolean  @default(true)
  downloads      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([slug])
  @@index([category])
  @@index([isActive])
  @@map("documents")
}

model AnimalType {
  id                  String          @id @default(cuid())
  name                String
  name_ar             String?
  slug                String          @unique
  description         String?         @db.Text
  description_ar      String?         @db.Text
  imageUrl            String?
  icon                String?
  order               Int             @default(0)
  isActive            Boolean         @default(true)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  category            String?
  category_ar         String?
  documentTitle       String?
  documentTitle_ar    String?
  metaTitle           String?
  metaTitle_ar        String?
  pdfUrl              String?
  pdfUrl_ar           String?
  productionSeason_ar String?
  issues              AnimalIssue[]
  tabs                AnimalTypeTab[]
  products            Product[]       @relation("animaltypetoproduct")

  @@index([slug])
  @@index([isActive])
  @@index([order])
  @@map("animal_types")
}

model AnimalIssue {
  id             String     @id @default(cuid())
  title          String
  title_ar       String?
  description    String?    @db.Text
  description_ar String?    @db.Text
  order          Int        @default(0)
  isActive       Boolean    @default(true)
  animalTypeId   String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  recommendation String?    @db.LongText
  animalType     AnimalType @relation(fields: [animalTypeId], references: [id], onDelete: Cascade)

  @@index([animalTypeId])
  @@index([isActive])
  @@index([order])
  @@map("animal_issues")
}

model AnimalTypeTab {
  id             String               @id @default(cuid())
  title          String
  title_ar       String?
  description    String?              @db.Text
  description_ar String?              @db.Text
  order          Int                  @default(0)
  animalTypeId   String
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  images         AnimalTypeTabImage[]
  animalType     AnimalType           @relation(fields: [animalTypeId], references: [id], onDelete: Cascade)

  @@index([animalTypeId])
  @@index([order])
  @@map("animal_type_tabs")
}

model AnimalTypeTabImage {
  id             String        @id @default(cuid())
  imageUrl       String
  title          String?
  title_ar       String?
  description    String?       @db.Text
  description_ar String?       @db.Text
  order          Int           @default(0)
  tabId          String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  tab            AnimalTypeTab @relation(fields: [tabId], references: [id], onDelete: Cascade)

  @@index([tabId])
  @@index([order])
  @@map("animal_type_tab_images")
}

model CustomFont {
  id          String   @id @default(cuid())
  name        String   @unique
  url         String
  fileName    String
  fileSize    Int
  mimeType    String
  displayName String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@map("custom_fonts")
}
